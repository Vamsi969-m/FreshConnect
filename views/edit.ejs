<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit <%= student.name %> - Recruitment Portal</title>
    <style>
        /* Base Styles */
        :root {
            --primary-color: #2c3e50;
            --secondary-color: #3498db;
            --accent-color: #e74c3c;
            --success-color: #27ae60;
            --warning-color: #f39c12;
            --light-color: #ecf0f1;
            --dark-color: #2c3e50;
            --gray-color: #95a5a6;
            --light-gray: #f8f9fa;
            --border-color: #ddd;
            --shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --shadow-hover: 0 8px 24px rgba(0, 0, 0, 0.15);
            --border-radius: 10px;
            --transition: all 0.3s ease;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
            color: #333;
            line-height: 1.6;
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
            background-color: white;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow);
            overflow: hidden;
        }
        
        /* Header Styles */
        .header {
            background: linear-gradient(to right, var(--primary-color), #34495e);
            color: white;
            padding: 25px 30px;
            position: relative;
        }
        
        .header-content {
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 20px;
        }
        
        .header h1 {
            font-size: 2rem;
            font-weight: 600;
            margin-bottom: 5px;
        }
        
        .header p {
            font-size: 1rem;
            opacity: 0.9;
        }
        
        .student-id {
            background-color: rgba(255, 255, 255, 0.15);
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-family: 'Courier New', monospace;
            margin-top: 8px;
        }
        
        /* Back Button */
        .back-link {
            color: white;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            padding: 8px 16px;
            background-color: rgba(255, 255, 255, 0.1);
            border-radius: var(--border-radius);
            transition: var(--transition);
        }
        
        .back-link:hover {
            background-color: rgba(255, 255, 255, 0.2);
        }
        
        /* Form Layout */
        .form-container {
            padding: 30px;
        }
        
        .form-section {
            margin-bottom: 35px;
            padding-bottom: 25px;
            border-bottom: 1px solid var(--light-color);
        }
        
        .form-section:last-of-type {
            border-bottom: none;
        }
        
        .section-title {
            color: var(--primary-color);
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        
        .section-title::before {
            content: '';
            display: block;
            width: 4px;
            height: 20px;
            background-color: var(--secondary-color);
            border-radius: 2px;
        }
        
        /* Form Grid */
        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
        }
        
        .full-width {
            grid-column: 1 / -1;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        /* Label and Input Styles */
        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--primary-color);
            display: flex;
            align-items: center;
            gap: 6px;
        }
        
        .required::after {
            content: ' *';
            color: var(--accent-color);
        }
        
        input[type="text"],
        input[type="email"],
        input[type="tel"],
        input[type="date"],
        input[type="number"],
        input[type="url"],
        textarea {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid var(--border-color);
            border-radius: var(--border-radius);
            font-size: 1rem;
            transition: var(--transition);
            background-color: var(--light-gray);
        }
        
        input:focus,
        textarea:focus {
            outline: none;
            border-color: var(--secondary-color);
            background-color: white;
            box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.2);
        }
        
        input[type="number"] {
            max-width: 150px;
        }
        
        /* Skills Grid */
        .skills-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
        }
        
        .skill-input-group {
            margin-bottom: 15px;
        }
        
        .input-hint {
            font-size: 0.85rem;
            color: var(--gray-color);
            margin-top: 5px;
            font-style: italic;
        }
        
        /* Tags Preview */
        .tags-preview {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 8px;
            min-height: 30px;
        }
        
        .tag {
            background-color: var(--light-color);
            padding: 4px 10px;
            border-radius: 15px;
            font-size: 0.85rem;
            color: var(--dark-color);
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }
        
        .tag-remove {
            background: none;
            border: none;
            color: var(--gray-color);
            cursor: pointer;
            font-size: 0.8rem;
            padding: 0;
            width: 16px;
            height: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
        }
        
        .tag-remove:hover {
            background-color: rgba(231, 76, 60, 0.1);
            color: var(--accent-color);
        }
        
        /* Form Actions */
        .form-actions {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 40px;
            padding-top: 30px;
            border-top: 1px solid var(--border-color);
            flex-wrap: wrap;
        }
        
        .btn {
            padding: 14px 30px;
            border-radius: var(--border-radius);
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            border: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
            min-width: 160px;
        }
        
        .btn-save {
            background: linear-gradient(to right, var(--success-color), #2ecc71);
            color: white;
            box-shadow: var(--shadow);
        }
        
        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-hover);
            background: linear-gradient(to right, #229954, #27ae60);
        }
        
        .btn-reset {
            background-color: var(--light-color);
            color: var(--primary-color);
        }
        
        .btn-reset:hover {
            background-color: #d5dbdb;
        }
        
        .btn-cancel {
            background-color: white;
            color: var(--accent-color);
            border: 2px solid var(--accent-color);
            text-decoration: none;
        }
        
        .btn-cancel:hover {
            background-color: #fdedec;
        }
        
        /* Validation Styles */
        .validation-message {
            font-size: 0.85rem;
            margin-top: 5px;
            padding: 5px 10px;
            border-radius: 4px;
            display: none;
        }
        
        .validation-error {
            color: var(--accent-color);
            background-color: #fdedec;
            display: block;
        }
        
        .validation-success {
            color: var(--success-color);
            background-color: #d5f4e6;
            display: block;
        }
        
        input:invalid:not(:focus):not(:placeholder-shown) {
            border-color: var(--accent-color);
        }
        
        input:valid:not(:focus):not(:placeholder-shown) {
            border-color: var(--success-color);
        }
        
        /* Loading State */
        .btn-loading {
            position: relative;
            color: transparent;
        }
        
        .btn-loading::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            top: 50%;
            left: 50%;
            margin-left: -10px;
            margin-top: -10px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        
        /* Tab Navigation */
        .form-tabs {
            display: flex;
            border-bottom: 1px solid var(--border-color);
            margin-bottom: 30px;
            overflow-x: auto;
        }
        
        .tab-btn {
            padding: 12px 24px;
            background: none;
            border: none;
            border-bottom: 3px solid transparent;
            font-weight: 600;
            color: var(--gray-color);
            cursor: pointer;
            transition: var(--transition);
            white-space: nowrap;
        }
        
        .tab-btn:hover {
            color: var(--primary-color);
        }
        
        .tab-btn.active {
            color: var(--secondary-color);
            border-bottom-color: var(--secondary-color);
        }
        
        .tab-content {
            display: none;
        }
        
        .tab-content.active {
            display: block;
        }
        
        /* Responsive Design */
        @media (max-width: 768px) {
            .header-content {
                flex-direction: column;
                align-items: flex-start;
            }
            
            .form-container {
                padding: 20px;
            }
            
            .form-grid {
                grid-template-columns: 1fr;
            }
            
            .skills-grid {
                grid-template-columns: 1fr;
            }
            
            .form-actions {
                flex-direction: column;
                align-items: center;
            }
            
            .btn {
                width: 100%;
                max-width: 300px;
            }
            
            .form-tabs {
                flex-wrap: wrap;
            }
            
            .tab-btn {
                flex: 1;
                text-align: center;
                min-width: 120px;
            }
        }
        
        /* Tooltip */
        .tooltip {
            position: relative;
            display: inline-block;
        }
        
        .tooltip-icon {
            color: var(--secondary-color);
            cursor: help;
            font-size: 0.9rem;
            width: 18px;
            height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
            border: 1px solid var(--secondary-color);
        }
        
        .tooltip-text {
            visibility: hidden;
            width: 200px;
            background-color: var(--primary-color);
            color: white;
            text-align: center;
            border-radius: var(--border-radius);
            padding: 8px;
            position: absolute;
            z-index: 1;
            bottom: 125%;
            left: 50%;
            transform: translateX(-50%);
            opacity: 0;
            transition: opacity 0.3s;
            font-size: 0.85rem;
            font-weight: normal;
        }
        
        .tooltip:hover .tooltip-text {
            visibility: visible;
            opacity: 1;
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <div class="header-content">
                <div>
                    <a href="/students/<%= student.uuid %>" class="back-link">
                        ← Back to Profile
                    </a>
                    <h1>Edit Student Profile</h1>
                    <p>Update information for <%= student.name %></p>
                    <div class="student-id">ID: <%= student.uuid %></div>
                </div>
            </div>
        </div>
        
        <!-- Tab Navigation -->
        <div class="form-tabs">
            <button class="tab-btn active" data-tab="personal">Personal Info</button>
            <button class="tab-btn" data-tab="skills">Skills</button>
            <button class="tab-btn" data-tab="profiles">Profiles</button>
            <button class="tab-btn" data-tab="additional">Additional</button>
        </div>
        
        <!-- Form -->
        <div class="form-container">
            <form action="/students/<%= student.uuid %>" method="POST" id="editForm">
                <input type="hidden" name="_method" value="PUT">
                
                <!-- Personal Information Tab -->
                <div id="personal-tab" class="tab-content active">
                    <div class="form-section">
                        <h2 class="section-title">Personal Information</h2>
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="name" class="required">
                                    Full Name
                                    <span class="tooltip">
                                        <span class="tooltip-icon">?</span>
                                        <span class="tooltip-text">Enter the student's full name as it should appear on official documents</span>
                                    </span>
                                </label>
                                <input type="text" id="name" name="name" value="<%= student.name %>" required 
                                       placeholder="John Doe">
                            </div>
                            
                            <div class="form-group">
                                <label for="email" class="required">Email Address</label>
                                <input type="email" id="email" name="email" value="<%= student.email %>" required 
                                       placeholder="student@example.com">
                            </div>
                            
                            <div class="form-group">
                                <label for="phone" class="required">Phone Number</label>
                                <input type="tel" id="phone" name="phone" value="<%= student.phone %>" required 
                                       placeholder="+1 (555) 123-4567">
                            </div>
                            
                            <div class="form-group">
                                <label for="dob" class="required">Date of Birth</label>
                                <input type="date" id="dob" name="Dob" 
                                       value="<%= student.Dob ? new Date(student.Dob).toISOString().substring(0,10) : '' %>" required>
                            </div>
                            
                            <div class="form-group">
                                <label for="college" class="required">College/University</label>
                                <input type="text" id="college" name="college" value="<%= student.college %>" required 
                                       placeholder="Massachusetts Institute of Technology">
                            </div>
                            
                            <div class="form-group">
                                <label for="course" class="required">Course/Program</label>
                                <input type="text" id="course" name="course" value="<%= student.course %>" required 
                                       placeholder="Bachelor of Computer Science">
                            </div>
                            
                            <div class="form-group">
                                <label for="cgpa" class="required">CGPA</label>
                                <input type="number" id="cgpa" name="cgpa" step="0.01" min="0" max="10" 
                                       value="<%= student.cgpa %>" required placeholder="8.5">
                                <div class="input-hint">Scale: 0.0 - 10.0</div>
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-section">
                        <h2 class="section-title">Career Objective</h2>
                        <div class="form-group full-width">
                            <textarea id="aim" name="Aim" rows="4" 
                                      placeholder="Briefly describe your career goals and aspirations..."><%= student.Aim %></textarea>
                        </div>
                    </div>
                </div>
                
                <!-- Skills Tab -->
                <div id="skills-tab" class="tab-content">
                    <div class="form-section">
                        <h2 class="section-title">Technical Skills
                            <span class="tooltip">
                                <span class="tooltip-icon">?</span>
                                <span class="tooltip-text">Enter skills separated by commas. They will be displayed as tags.</span>
                            </span>
                        </h2>
                        <div class="skills-grid">
                            <div class="skill-input-group">
                                <label for="databases">Databases</label>
                                <input type="text" id="databases" name="skills[DataBase]" 
                                       value="<%= student.skills.DataBase.join(', ') %>"
                                       placeholder="MySQL, MongoDB, PostgreSQL">
                                <div class="tags-preview" id="databases-tags"></div>
                            </div>
                            
                            <div class="skill-input-group">
                                <label for="programming">Programming Languages</label>
                                <input type="text" id="programming" name="skills[ProgrammingLanguages]" 
                                       value="<%= student.skills.ProgrammingLanguages.join(', ') %>"
                                       placeholder="Java, Python, JavaScript, C++">
                                <div class="tags-preview" id="programming-tags"></div>
                            </div>
                            
                            <div class="skill-input-group">
                                <label for="frameworks">Frameworks</label>
                                <input type="text" id="frameworks" name="skills[FrameWorks]" 
                                       value="<%= student.skills.FrameWorks.join(', ') %>"
                                       placeholder="Express.js, Spring Boot, React">
                                <div class="tags-preview" id="frameworks-tags"></div>
                            </div>
                            
                            <div class="skill-input-group">
                                <label for="frontend">Frontend Technologies</label>
                                <input type="text" id="frontend" name="skills[Frontend]" 
                                       value="<%= student.skills.Frontend.join(', ') %>"
                                       placeholder="HTML5, CSS3, JavaScript, React">
                                <div class="tags-preview" id="frontend-tags"></div>
                            </div>
                            
                            <div class="skill-input-group">
                                <label for="backend">Backend Technologies</label>
                                <input type="text" id="backend" name="skills[Backend]" 
                                       value="<%= student.skills.Backend.join(', ') %>"
                                       placeholder="Node.js, Django, REST APIs">
                                <div class="tags-preview" id="backend-tags"></div>
                            </div>
                            
                            <div class="skill-input-group">
                                <label for="tools">Development Tools</label>
                                <input type="text" id="tools" name="skills[Tools]" 
                                       value="<%= student.skills.Tools.join(', ') %>"
                                       placeholder="Git, Docker, VS Code, Postman">
                                <div class="tags-preview" id="tools-tags"></div>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Profiles Tab -->
                <div id="profiles-tab" class="tab-content">
                    <div class="form-section">
                        <h2 class="section-title">Professional Profiles</h2>
                        <div class="form-grid">
                            <div class="form-group">
                                <label for="github">GitHub Profile URL</label>
                                <input type="url" id="github" name="codingProfiles.github" 
                                       value="<%= student.codingProfiles.github %>"
                                       placeholder="https://github.com/username">
                            </div>
                            
                            <div class="form-group">
                                <label for="linkedin">LinkedIn Profile URL</label>
                                <input type="url" id="linkedin" name="codingProfiles.linkedin" 
                                       value="<%= student.codingProfiles.linkedIn %>"
                                       placeholder="https://linkedin.com/in/username">
                            </div>
                        </div>
                    </div>
                    
                    <div class="form-section">
                        <h2 class="section-title">Additional Links</h2>
                        <div class="form-group full-width">
                            <textarea id="otherLinks" name="otherLinks" rows="3" 
                                      placeholder="Add any additional portfolio or project links, one per line..."></textarea>
                            <div class="input-hint">Enter one link per line. Format: Title|URL</div>
                        </div>
                    </div>
                </div>
                
                <!-- Additional Tab -->
                <div id="additional-tab" class="tab-content">
                    <div class="form-section">
                        <h2 class="section-title">Certifications</h2>
                        <div class="form-group full-width">
                            <input type="text" id="certifications" name="certifications" 
                                   value="<%= student.certifications.join(', ') %>"
                                   placeholder="AWS Certified Solutions Architect, Google Cloud Professional, Oracle Certified">
                            <div class="input-hint">Separate multiple certifications with commas</div>
                            <div class="tags-preview" id="certifications-tags"></div>
                        </div>
                    </div>
                    
                    <div class="form-section">
                        <h2 class="section-title">Other Activities & Achievements</h2>
                        <div class="form-group full-width">
                            <textarea id="activities" name="other_activities" rows="4"
                                      placeholder="Hackathon Winner (2023), Research Paper Published in IEEE, NSS Volunteer..."><%= student.other_activities.join(', ') %></textarea>
                            <div class="input-hint">Include extracurricular activities, awards, publications, etc.</div>
                            <div class="tags-preview" id="activities-tags"></div>
                        </div>
                    </div>
                </div>
                
                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn btn-save">
                        💾 Update Student Profile
                    </button>
                    <button type="reset" class="btn btn-reset">
                        ↺ Reset Changes
                    </button>
                    <a href="/students/<%= student.uuid %>" class="btn btn-cancel">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('editForm');
            const submitBtn = form.querySelector('.btn-save');
            const tabBtns = document.querySelectorAll('.tab-btn');
            const tabContents = document.querySelectorAll('.tab-content');
            
            // Tab Navigation
            tabBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    const tabId = this.getAttribute('data-tab');
                    
                    // Update active tab button
                    tabBtns.forEach(b => b.classList.remove('active'));
                    this.classList.add('active');
                    
                    // Show active tab content
                    tabContents.forEach(content => {
                        content.classList.remove('active');
                        if (content.id === `${tabId}-tab`) {
                            content.classList.add('active');
                        }
                    });
                });
            });
            
            // Skill tag preview functionality
            const skillInputs = [
                { id: 'databases', previewId: 'databases-tags' },
                { id: 'programming', previewId: 'programming-tags' },
                { id: 'frameworks', previewId: 'frameworks-tags' },
                { id: 'frontend', previewId: 'frontend-tags' },
                { id: 'backend', previewId: 'backend-tags' },
                { id: 'tools', previewId: 'tools-tags' },
                { id: 'certifications', previewId: 'certifications-tags' }
            ];
            
            // Initialize tag previews
            skillInputs.forEach(skill => {
                const input = document.getElementById(skill.id);
                const preview = document.getElementById(skill.previewId);
                
                function updateTags() {
                    preview.innerHTML = '';
                    const value = input.value.trim();
                    if (value) {
                        const tags = value.split(',').map(tag => tag.trim()).filter(tag => tag);
                        tags.forEach(tag => {
                            const tagElement = document.createElement('span');
                            tagElement.className = 'tag';
                            tagElement.innerHTML = `
                                ${tag}
                                <button type="button" class="tag-remove" data-tag="${tag}">×</button>
                            `;
                            preview.appendChild(tagElement);
                        });
                        
                        // Add remove functionality
                        preview.querySelectorAll('.tag-remove').forEach(removeBtn => {
                            removeBtn.addEventListener('click', function() {
                                const tagToRemove = this.getAttribute('data-tag');
                                const currentTags = input.value.split(',').map(t => t.trim()).filter(t => t);
                                const updatedTags = currentTags.filter(t => t !== tagToRemove);
                                input.value = updatedTags.join(', ');
                                updateTags();
                            });
                        });
                    }
                }
                
                // Update tags on input
                input.addEventListener('input', updateTags);
                
                // Initialize with current values
                updateTags();
            });
            
            // Activities tag preview
            const activitiesInput = document.getElementById('activities');
            const activitiesPreview = document.getElementById('activities-tags');
            
            function updateActivityTags() {
                activitiesPreview.innerHTML = '';
                const value = activitiesInput.value.trim();
                if (value) {
                    const activities = value.split(',').map(act => act.trim()).filter(act => act);
                    activities.forEach(activity => {
                        const tagElement = document.createElement('span');
                        tagElement.className = 'tag';
                        tagElement.innerHTML = `
                            ${activity}
                            <button type="button" class="tag-remove" data-activity="${activity}">×</button>
                        `;
                        activitiesPreview.appendChild(tagElement);
                    });
                    
                    activitiesPreview.querySelectorAll('.tag-remove').forEach(removeBtn => {
                        removeBtn.addEventListener('click', function() {
                            const activityToRemove = this.getAttribute('data-activity');
                            const currentActivities = activitiesInput.value.split(',').map(a => a.trim()).filter(a => a);
                            const updatedActivities = currentActivities.filter(a => a !== activityToRemove);
                            activitiesInput.value = updatedActivities.join(', ');
                            updateActivityTags();
                        });
                    });
                }
            }
            
            activitiesInput.addEventListener('input', updateActivityTags);
            updateActivityTags();
            
            // Form validation
            const requiredFields = form.querySelectorAll('[required]');
            
            function validateField(field) {
                const value = field.value.trim();
                const parent = field.parentElement;
                let errorElement = parent.querySelector('.validation-message');
                
                if (!errorElement) {
                    errorElement = document.createElement('div');
                    errorElement.className = 'validation-message';
                    parent.appendChild(errorElement);
                }
                
                if (field.hasAttribute('required') && !value) {
                    errorElement.textContent = 'This field is required';
                    errorElement.className = 'validation-message validation-error';
                    return false;
                }
                
                if (field.type === 'email' && value) {
                    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                    if (!emailRegex.test(value)) {
                        errorElement.textContent = 'Please enter a valid email address';
                        errorElement.className = 'validation-message validation-error';
                        return false;
                    }
                }
                
                if (field.id === 'cgpa' && value) {
                    const cgpa = parseFloat(value);
                    if (isNaN(cgpa) || cgpa < 0 || cgpa > 10) {
                        errorElement.textContent = 'CGPA must be between 0.0 and 10.0';
                        errorElement.className = 'validation-message validation-error';
                        return false;
                    }
                }
                
                if (field.id === 'dob' && value) {
                    const dob = new Date(value);
                    const today = new Date();
                    const minAgeDate = new Date(today.getFullYear() - 16, today.getMonth(), today.getDate());
                    
                    if (dob > minAgeDate) {
                        errorElement.textContent = 'Student must be at least 16 years old';
                        errorElement.className = 'validation-message validation-error';
                        return false;
                    }
                }
                
                errorElement.className = 'validation-message';
                return true;
            }
            
            // Real-time validation
            requiredFields.forEach(field => {
                field.addEventListener('blur', () => validateField(field));
                field.addEventListener('input', () => {
                    const errorElement = field.parentElement.querySelector('.validation-message');
                    if (errorElement) {
                        errorElement.className = 'validation-message';
                    }
                });
            });
            
            // Form submission
            form.addEventListener('submit', function(e) {
                e.preventDefault();
                
                let isValid = true;
                const firstInvalidField = [];
                
                requiredFields.forEach(field => {
                    if (!validateField(field)) {
                        isValid = false;
                        if (firstInvalidField.length === 0) {
                            firstInvalidField.push(field);
                        }
                    }
                });
                
                if (!isValid) {
                    alert('Please fix the errors in the form before submitting.');
                    if (firstInvalidField[0]) {
                        firstInvalidField[0].focus();
                        firstInvalidField[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                    return;
                }
                
                // Show loading state
                submitBtn.classList.add('btn-loading');
                submitBtn.disabled = true;
                
                // Submit the form after validation
                setTimeout(() => {
                    this.submit();
                }, 500);
            });
            
            // Age calculation display
            const dobInput = document.getElementById('dob');
            const dobLabel = dobInput.previousElementSibling;
            
            function updateAgeDisplay() {
                if (dobInput.value) {
                    const dob = new Date(dobInput.value);
                    const today = new Date();
                    let age = today.getFullYear() - dob.getFullYear();
                    const m = today.getMonth() - dob.getMonth();
                    if (m < 0 || (m === 0 && today.getDate() < dob.getDate())) {
                        age--;
                    }
                    
                    const ageDisplay = document.getElementById('age-display') || document.createElement('span');
                    ageDisplay.id = 'age-display';
                    ageDisplay.textContent = ` (${age} years)`;
                    ageDisplay.style.color = 'var(--secondary-color)';
                    ageDisplay.style.fontWeight = '600';
                    ageDisplay.style.marginLeft = '5px';
                    
                    if (!dobLabel.querySelector('#age-display')) {
                        dobLabel.appendChild(ageDisplay);
                    }
                }
            }
            
            dobInput.addEventListener('change', updateAgeDisplay);
            updateAgeDisplay();
            
            // Auto-focus first field
            const firstField = form.querySelector('input[required]');
            if (firstField) {
                firstField.focus();
            }
        });
    </script>
</body>
</html>