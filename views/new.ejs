<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add New Student - Recruitment Portal</title>
    <style>
        /* Base Styles */
        :root {
            --primary-color: #2c3e50;
            --secondary-color: #3498db;
            --accent-color: #e74c3c;
            --success-color: #27ae60;
            --warning-color: #f39c12;
            --light-color: #ecf0f1;
            --dark-color: #2c3e50;
            --gray-color: #95a5a6;
            --light-gray: #f8f9fa;
            --border-color: #ddd;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --shadow-hover: 0 6px 12px rgba(0, 0, 0, 0.15);
            --border-radius: 8px;
            --transition: all 0.3s ease;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            color: #333;
            line-height: 1.6;
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 1000px;
            margin: 0 auto;
            background-color: white;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow);
            overflow: hidden;
        }
        
        /* Header Styles */
        .header {
            background: linear-gradient(to right, var(--primary-color), var(--secondary-color));
            color: white;
            padding: 25px 30px;
            text-align: center;
        }
        
        .header h1 {
            font-size: 2.2rem;
            font-weight: 600;
            margin-bottom: 8px;
        }
        
        .header p {
            font-size: 1.1rem;
            opacity: 0.9;
        }
        
        .back-link {
            position: absolute;
            top: 30px;
            left: 30px;
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 500;
            transition: var(--transition);
        }
        
        .back-link:hover {
            opacity: 0.8;
        }
        
        /* Form Layout */
        .form-container {
            padding: 30px;
        }
        
        .form-section {
            margin-bottom: 35px;
        }
        
        .section-title {
            color: var(--primary-color);
            font-size: 1.4rem;
            font-weight: 600;
            margin-bottom: 20px;
            padding-bottom: 10px;
            border-bottom: 2px solid var(--light-color);
            position: relative;
        }
        
        .section-title::after {
            content: '';
            position: absolute;
            bottom: -2px;
            left: 0;
            width: 70px;
            height: 2px;
            background-color: var(--secondary-color);
        }
        
        /* Form Grid */
        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }
        
        .form-group {
            margin-bottom: 20px;
        }
        
        .full-width {
            grid-column: 1 / -1;
        }
        
        label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--primary-color);
        }
        
        .required::after {
            content: ' *';
            color: var(--accent-color);
        }
        
        /* Input Styles */
        input[type="text"],
        input[type="email"],
        input[type="tel"],
        input[type="date"],
        input[type="number"],
        input[type="url"],
        textarea,
        select {
            width: 100%;
            padding: 12px 15px;
            border: 2px solid var(--border-color);
            border-radius: var(--border-radius);
            font-size: 1rem;
            transition: var(--transition);
            background-color: var(--light-gray);
        }
        
        input:focus,
        textarea:focus,
        select:focus {
            outline: none;
            border-color: var(--secondary-color);
            background-color: white;
            box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.2);
        }
        
        input[type="number"] {
            max-width: 150px;
        }
        
        textarea {
            resize: vertical;
            min-height: 100px;
            font-family: inherit;
        }
        
        /* Skill Tags Input */
        .skills-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 15px;
        }
        
        .skill-input-group {
            margin-bottom: 15px;
        }
        
        .skill-hint {
            font-size: 0.85rem;
            color: var(--gray-color);
            margin-top: 5px;
            font-style: italic;
        }
        
        /* Button Styles */
        .form-actions {
            display: flex;
            justify-content: center;
            gap: 20px;
            margin-top: 40px;
            padding-top: 30px;
            border-top: 1px solid var(--border-color);
        }
        
        .btn {
            padding: 14px 30px;
            border-radius: var(--border-radius);
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            border: none;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            text-decoration: none;
            min-width: 160px;
        }
        
        .btn-submit {
            background: linear-gradient(to right, var(--secondary-color), #2980b9);
            color: white;
            box-shadow: var(--shadow);
        }
        
        .btn-submit:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-hover);
        }
        
        .btn-reset {
            background-color: var(--light-color);
            color: var(--primary-color);
        }
        
        .btn-reset:hover {
            background-color: #d5dbdb;
        }
        
        .btn-cancel {
            background-color: white;
            color: var(--accent-color);
            border: 2px solid var(--accent-color);
        }
        
        .btn-cancel:hover {
            background-color: #fdedec;
        }
        
        /* Form Validation Styles */
        input:invalid:not(:placeholder-shown) {
            border-color: var(--accent-color);
        }
        
        input:valid:not(:placeholder-shown) {
            border-color: var(--success-color);
        }
        
        /* Progress Indicator */
        .progress-bar {
            height: 4px;
            background-color: var(--light-color);
            margin-bottom: 30px;
            border-radius: 2px;
            overflow: hidden;
        }
        
        .progress-fill {
            height: 100%;
            background: linear-gradient(to right, var(--secondary-color), var(--success-color));
            width: 33.33%;
            transition: width 0.5s ease;
        }
        
        /* Tooltip */
        .tooltip {
            position: relative;
            display: inline-block;
            margin-left: 5px;
        }
        
        .tooltip-icon {
            color: var(--secondary-color);
            cursor: help;
            font-weight: bold;
            font-size: 0.9rem;
        }
        
        .tooltip-text {
            visibility: hidden;
            width: 200px;
            background-color: var(--primary-color);
            color: white;
            text-align: center;
            border-radius: var(--border-radius);
            padding: 8px;
            position: absolute;
            z-index: 1;
            bottom: 125%;
            left: 50%;
            transform: translateX(-50%);
            opacity: 0;
            transition: opacity 0.3s;
            font-size: 0.85rem;
            font-weight: normal;
        }
        
        .tooltip:hover .tooltip-text {
            visibility: visible;
            opacity: 1;
        }
        
        /* Responsive Design */
        @media (max-width: 768px) {
            .container {
                margin: 10px;
            }
            
            .header {
                padding: 20px;
            }
            
            .header h1 {
                font-size: 1.8rem;
            }
            
            .form-container {
                padding: 20px;
            }
            
            .form-grid {
                grid-template-columns: 1fr;
            }
            
            .form-actions {
                flex-direction: column;
                align-items: center;
            }
            
            .btn {
                width: 100%;
                max-width: 300px;
            }
            
            .back-link {
                position: relative;
                top: 0;
                left: 0;
                margin-bottom: 15px;
                justify-content: center;
            }
        }
        
        /* Focus Indicator for Accessibility */
        *:focus {
            outline: 2px solid var(--secondary-color);
            outline-offset: 2px;
        }
        
        /* Loading State */
        .btn-loading {
            position: relative;
            color: transparent;
        }
        
        .btn-loading::after {
            content: '';
            position: absolute;
            width: 20px;
            height: 20px;
            top: 50%;
            left: 50%;
            margin-left: -10px;
            margin-top: -10px;
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Header -->
        <div class="header">
            <a href="/students" class="back-link">
                ← Back to Dashboard
            </a>
            <h1>Add New Student</h1>
            <p>Fill in the student details below for recruitment processing</p>
        </div>
        
        <!-- Progress Indicator -->
        <div class="progress-bar">
            <div class="progress-fill"></div>
        </div>
        
        <!-- Form -->
        <div class="form-container">
            <form action="/students" method="POST" id="studentForm">
                <!-- Personal Information Section -->
                <div class="form-section">
                    <h2 class="section-title">Personal Information</h2>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="aim" class="required">Career Objective</label>
                            <input type="text" id="aim" name="Aim" required 
                            placeholder="e.g., To become a full-stack developer">
                        </div>
                        
                        <div class="form-group">
                            <label for="name" class="required">Full Name</label>
                            <input type="text" id="name" name="name" required 
                            placeholder="Enter student's full name">
                        </div>
                        
                        <div class="form-group">
                            <label for="college" class="required">College/University</label>
                            <input type="text" id="college" name="college" required 
                                   placeholder="e.g., MIT, Stanford University">
                        </div>
                        
                        <div class="form-group">
                            <label for="phone" class="required">Phone Number</label>
                            <input type="tel" id="phone" name="phone" required 
                                   placeholder="+1 (555) 123-4567">
                        </div>
                        
                        <div class="form-group">
                            <label for="email" class="required">Email Address</label>
                            <input type="email" id="email" name="email" required 
                                   placeholder="student@example.com">
                        </div>
                        
                        <div class="form-group">
                            <label for="dob" class="required">Date of Birth</label>
                            <input type="date" id="dob" name="Dob" required>
                        </div>
                        
                        <div class="form-group">
                            <label for="course" class="required">Course/Program</label>
                            <input type="text" id="course" name="course" required 
                                   placeholder="e.g., Computer Science, B.Tech">
                        </div>
                        
                        <div class="form-group">
                            <label for="cgpa" class="required">CGPA</label>
                            <input type="number" id="cgpa" name="cgpa" step="0.01" min="0" max="10" required 
                                   placeholder="8.5">
                            <span class="skill-hint">Scale: 0.0 - 10.0</span>
                        </div>
                    </div>
                </div>
                
                <!-- Technical Skills Section -->
                <div class="form-section">
                    <h2 class="section-title">Technical Skills
                        <span class="tooltip">
                            <span class="tooltip-icon">?</span>
                            <span class="tooltip-text">Enter skills separated by commas (e.g., Java, Python, React)</span>
                        </span>
                    </h2>
                    <div class="skills-container">
                        <div class="skill-input-group">
                            <label for="databases">Databases</label>
                            <input type="text" id="databases" name="skills[DataBase]" 
                                   placeholder="MySQL, MongoDB, PostgreSQL">
                        </div>
                        
                        <div class="skill-input-group">
                            <label for="programming">Programming Languages</label>
                            <input type="text" id="programming" name="skills[ProgrammingLanguages]" 
                                   placeholder="Java, Python, JavaScript, C++">
                        </div>
                        
                        <div class="skill-input-group">
                            <label for="frameworks">Frameworks</label>
                            <input type="text" id="frameworks" name="skills[FrameWorks]" 
                                   placeholder="Express.js, Spring Boot, React">
                        </div>
                        
                        <div class="skill-input-group">
                            <label for="frontend">Frontend Technologies</label>
                            <input type="text" id="frontend" name="skills[Frontend]" 
                                   placeholder="HTML5, CSS3, JavaScript, React">
                        </div>
                        
                        <div class="skill-input-group">
                            <label for="backend">Backend Technologies</label>
                            <input type="text" id="backend" name="skills[Backend]" 
                                   placeholder="Node.js, Django, REST APIs">
                        </div>
                        
                        <div class="skill-input-group">
                            <label for="tools">Development Tools</label>
                            <input type="text" id="tools" name="skills[Tools]" 
                                   placeholder="Git, Docker, VS Code, Postman">
                        </div>
                    </div>
                </div>
                
                <!-- Professional Profiles Section -->
                <div class="form-section">
                    <h2 class="section-title">Professional Profiles</h2>
                    <div class="form-grid">
                        <div class="form-group">
                            <label for="github">GitHub Profile</label>
                            <input type="url" id="github" name="codingProfiles.github" 
                                   placeholder="https://github.com/username">
                        </div>
                        
                        <div class="form-group">
                            <label for="linkedin">LinkedIn Profile</label>
                            <input type="url" id="linkedin" name="codingProfiles.linkedin" 
                                   placeholder="https://linkedin.com/in/username">
                        </div>
                    </div>
                </div>
                
                <!-- Additional Information Section -->
                <div class="form-section">
                    <h2 class="section-title">Additional Information</h2>
                    <div class="form-grid">
                        <div class="form-group full-width">
                            <label for="certifications">Certifications</label>
                            <input type="text" id="certifications" name="certifications" 
                                   placeholder="AWS Certified, Google Cloud, Oracle Certified">
                            <span class="skill-hint">Separate multiple certifications with commas</span>
                        </div>
                        
                        <div class="form-group full-width">
                            <label for="activities">Other Activities & Achievements</label>
                            <input type="text" id="activities" name="other_activities" 
                                   placeholder="Hackathon Winner, NSS Volunteer, Research Paper Published">
                            <span class="skill-hint">Include extracurricular activities, awards, publications</span>
                        </div>
                    </div>
                </div>
                
                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn btn-submit">
                        Add Student to Database
                    </button>
                    <button type="reset" class="btn btn-reset">
                        Clear Form
                    </button>
                    <a href="/students" class="btn btn-cancel">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Form enhancement and validation
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('studentForm');
            const submitBtn = form.querySelector('button[type="submit"]');
            const progressFill = document.querySelector('.progress-fill');
            
            // Real-time validation feedback
            const inputs = form.querySelectorAll('input[required]');
            inputs.forEach(input => {
                input.addEventListener('blur', function() {
                    if (this.value.trim() === '') {
                        this.style.borderColor = 'var(--accent-color)';
                    } else {
                        this.style.borderColor = 'var(--success-color)';
                    }
                });
            });
            
            // Form submission with loading state
            form.addEventListener('submit', function(e) {
                let isValid = true;
                
                // Check required fields
                inputs.forEach(input => {
                    if (input.value.trim() === '') {
                        isValid = false;
                        input.style.borderColor = 'var(--accent-color)';
                        input.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    }
                });
                
                if (!isValid) {
                    e.preventDefault();
                    alert('Please fill in all required fields marked with *');
                    return;
                }
                
                // Show loading state
                submitBtn.classList.add('btn-loading');
                submitBtn.disabled = true;
                
                // Simulate progress animation
                let progress = 33;
                const progressInterval = setInterval(() => {
                    progress += Math.random() * 10;
                    if (progress > 100) progress = 100;
                    progressFill.style.width = progress + '%';
                    
                    if (progress >= 100) {
                        clearInterval(progressInterval);
                    }
                }, 100);
            });
            
            // Progress indicator based on form completion
            function updateProgress() {
                const totalFields = inputs.length;
                let filledFields = 0;
                
                inputs.forEach(input => {
                    if (input.value.trim() !== '') {
                        filledFields++;
                    }
                });
                
                const percentage = (filledFields / totalFields) * 100;
                progressFill.style.width = percentage + '%';
            }
            
            // Update progress on input
            inputs.forEach(input => {
                input.addEventListener('input', updateProgress);
            });
            
            // Date validation - ensure student is at least 16 years old
            const dobInput = document.getElementById('dob');
            dobInput.addEventListener('change', function() {
                const selectedDate = new Date(this.value);
                const today = new Date();
                const minAgeDate = new Date(today.getFullYear() - 16, today.getMonth(), today.getDate());
                
                if (selectedDate > minAgeDate) {
                    alert('Student must be at least 16 years old');
                    this.value = '';
                    this.focus();
                }
            });
            
            // CGPA validation
            const cgpaInput = document.getElementById('cgpa');
            cgpaInput.addEventListener('change', function() {
                const value = parseFloat(this.value);
                if (value < 0 || value > 10) {
                    alert('CGPA must be between 0.0 and 10.0');
                    this.value = '';
                    this.focus();
                }
            });
            
            // Initialize progress
            updateProgress();
            
            // Auto-format skills input with suggestion
            const skillInputs = document.querySelectorAll('.skills-container input');
            skillInputs.forEach(input => {
                input.addEventListener('focus', function() {
                    if (!this.getAttribute('data-original-placeholder')) {
                        this.setAttribute('data-original-placeholder', this.placeholder);
                    }
                });
                
                input.addEventListener('blur', function() {
                    if (this.value.trim()) {
                        // Convert to proper case and remove extra spaces
                        let skills = this.value.split(',').map(skill => {
                            return skill.trim().charAt(0).toUpperCase() + skill.trim().slice(1).toLowerCase();
                        });
                        this.value = skills.join(', ');
                    }
                });
            });
        });
    </script>
</body>
</html>
