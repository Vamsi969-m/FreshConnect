<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Freshers Recruitment Portal</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" integrity="sha512-2SwdPD6INVrV/lHTZbO2nodKhrnDdJK9/kg2XD1r9uGqPo1cUbujc+IYdlYdEErWNu69gVcYgdxlmVmzTWnetw==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    <style>
        /* Base Styles */
        :root {
            --primary-color: #2c3e50;
            --secondary-color: #3498db;
            --accent-color: #e74c3c;
            --success-color: #27ae60;
            --warning-color: #f39c12;
            --light-color: #ecf0f1;
            --dark-color: #2c3e50;
            --gray-color: #7f8c8d;
            --light-gray: #f8f9fa;
            --shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --shadow-hover: 0 6px 12px rgba(0, 0, 0, 0.15);
            --border-radius: 8px;
            --transition: all 0.3s ease;
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        
        body {
            background-color: #f5f7fa;
            color: #333;
            line-height: 1.6;
            padding: 20px;
            max-width: 1400px;
            margin: 0 auto;
        }
        
        /* Header Styles */
        header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 1px solid #ddd;
            flex-wrap: wrap;
            gap: 20px;
        }
        
        .header-content {
            flex: 1;
        }
        
        h1 {
            color: var(--primary-color);
            font-size: 2.5rem;
            font-weight: 700;
            margin-bottom: 5px;
        }
        
        .subtitle {
            color: var(--gray-color);
            font-size: 1.1rem;
            margin-top: 5px;
        }
        
        /* Button Styles */
        .btn-primary {
            background-color: var(--secondary-color);
            color: white;
            border: none;
            padding: 12px 24px;
            border-radius: var(--border-radius);
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            text-decoration: none;
            box-shadow: var(--shadow);
            white-space: nowrap;
        }
        
        .btn-primary:hover {
            background-color: #2980b9;
            transform: translateY(-2px);
            box-shadow: var(--shadow-hover);
        }
        
        .btn-primary:active {
            transform: translateY(0);
        }
        
        /* Search and Filter Section */
        .search-filter-container {
            background-color: white;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow);
            padding: 25px;
            margin-bottom: 30px;
        }
        
        .search-section {
            display: flex;
            gap: 15px;
            margin-bottom: 25px;
            flex-wrap: wrap;
        }
        
        .search-input-group {
            flex: 1;
            min-width: 300px;
            position: relative;
        }
        
        .search-input {
            width: 100%;
            padding: 12px 45px 12px 15px;
            border: 2px solid var(--light-color);
            border-radius: var(--border-radius);
            font-size: 1rem;
            transition: var(--transition);
        }
        
        .search-input:focus {
            outline: none;
            border-color: var(--secondary-color);
            box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.2);
        }
        
        .search-icon {
            position: absolute;
            right: 15px;
            top: 50%;
            transform: translateY(-50%);
            color: var(--gray-color);
        }
        
        .clear-search {
            background-color: var(--light-color);
            color: var(--primary-color);
            border: none;
            padding: 12px 20px;
            border-radius: var(--border-radius);
            font-weight: 600;
            cursor: pointer;
            transition: var(--transition);
            white-space: nowrap;
        }
        
        .clear-search:hover {
            background-color: #d5dbdb;
        }
        
        /* Filter Section */
        .filter-section {
            border-top: 1px solid var(--light-color);
            padding-top: 25px;
        }
        
        .filter-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 20px;
        }
        
        .filter-group {
            margin-bottom: 15px;
        }
        
        .filter-label {
            display: block;
            margin-bottom: 8px;
            font-weight: 600;
            color: var(--primary-color);
        }
        
        .filter-select {
            width: 100%;
            padding: 10px 15px;
            border: 2px solid var(--light-color);
            border-radius: var(--border-radius);
            font-size: 1rem;
            background-color: white;
            cursor: pointer;
            transition: var(--transition);
        }
        
        .filter-select:focus {
            outline: none;
            border-color: var(--secondary-color);
            box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.2);
        }
        
        .filter-actions {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid var(--light-color);
            flex-wrap: wrap;
            gap: 15px;
        }
        
        .filter-results {
            color: var(--gray-color);
            font-size: 0.95rem;
        }
        
        .filter-results strong {
            color: var(--primary-color);
        }
        
        .active-filters {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
            margin-top: 15px;
        }
        
        .active-filter-tag {
            background-color: var(--light-color);
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            color: var(--dark-color);
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        
        .active-filter-remove {
            background: none;
            border: none;
            color: var(--gray-color);
            cursor: pointer;
            font-size: 1.1rem;
            line-height: 1;
            padding: 0;
            width: 16px;
            height: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 50%;
        }
        
        .active-filter-remove:hover {
            background-color: rgba(231, 76, 60, 0.1);
            color: var(--accent-color);
        }
        
        /* Stats Bar */
        .stats-bar {
            display: flex;
            justify-content: space-between;
            background-color: white;
            padding: 15px 25px;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow);
            margin-bottom: 25px;
            flex-wrap: wrap;
            gap: 20px;
        }
        
        .stat-item {
            text-align: center;
            flex: 1;
            min-width: 150px;
        }
        
        .stat-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--secondary-color);
        }
        
        .stat-label {
            color: var(--gray-color);
            font-size: 0.9rem;
        }
        
        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            background-color: white;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow);
            margin: 30px 0;
        }
        
        .empty-state i {
            font-size: 4rem;
            color: var(--gray-color);
            margin-bottom: 20px;
        }
        
        .empty-state h3 {
            color: var(--primary-color);
            margin-bottom: 10px;
        }
        
        .empty-state p {
            color: var(--gray-color);
            max-width: 500px;
            margin: 0 auto;
        }
        
        /* Card Container */
        .card-container {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
            gap: 25px;
            margin-top: 30px;
        }
        
        /* Student Card */
        .card {
            background-color: white;
            border-radius: var(--border-radius);
            box-shadow: var(--shadow);
            padding: 25px;
            transition: var(--transition);
            position: relative;
            overflow: hidden;
        }
        
        .card:hover {
            transform: translateY(-5px);
            box-shadow: var(--shadow-hover);
        }
        
        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 15px;
        }
        
        .card h3 {
            color: var(--primary-color);
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 5px;
        }
        
        .card-id {
            background-color: var(--light-gray);
            color: var(--gray-color);
            font-size: 0.8rem;
            padding: 4px 8px;
            border-radius: 4px;
        }
        
        .card-details p {
            margin-bottom: 12px;
            display: flex;
            align-items: center;
        }
        
        .card-details strong {
            color: var(--primary-color);
            min-width: 100px;
            display: inline-block;
        }
        
        .card-details span {
            color: #555;
        }
        
        .cgpa-badge {
            display: inline-block;
            background-color: var(--success-color);
            color: white;
            font-weight: bold;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 0.9rem;
        }
        
        .cgpa-low {
            background-color: var(--warning-color);
        }
        
        .cgpa-medium {
            background-color: #f1c40f;
        }
        
        .cgpa-high {
            background-color: var(--success-color);
        }
        
        /* Action Buttons */
        .actions {
            display: flex;
            justify-content: space-between;
            margin-top: 25px;
            padding-top: 20px;
            border-top: 1px solid #eee;
            flex-wrap: wrap;
            gap: 10px;
        }
        
        .btn {
            padding: 8px 16px;
            border-radius: 6px;
            text-decoration: none;
            font-weight: 600;
            font-size: 0.9rem;
            transition: var(--transition);
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        
        .btn-view {
            background-color: var(--success-color);
            color: white;
        }
        
        .btn-view:hover {
            background-color: #229954;
        }
        
        .btn-edit {
            background-color: #fef9e7;
            color: #f39c12;
        }
        
        .btn-edit:hover {
            background-color: #fcf3cf;
        }
        
        .btn-delete {
            background-color: #fdedec;
            color: var(--accent-color);
            border: none;
            cursor: pointer;
            font-family: inherit;
            font-weight: 600;
            font-size: 0.9rem;
            padding: 8px 16px;
            border-radius: 6px;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }
        
        .btn-delete:hover {
            background-color: #fadbd8;
        }
        
        /* Footer */
        footer {
            text-align: center;
            margin-top: 40px;
            padding-top: 20px;
            border-top: 1px solid #ddd;
            color: var(--gray-color);
            font-size: 0.9rem;
        }
        
        /* Responsive Design */
        @media (max-width: 768px) {
            header {
                flex-direction: column;
                align-items: flex-start;
            }
            
            h1 {
                font-size: 2rem;
            }
            
            .search-section {
                flex-direction: column;
            }
            
            .search-input-group {
                min-width: 100%;
            }
            
            .card-container {
                grid-template-columns: 1fr;
            }
            
            .stats-bar {
                flex-direction: column;
                gap: 20px;
            }
            
            .actions {
                flex-direction: column;
            }
            
            .btn {
                width: 100%;
                justify-content: center;
            }
        }
        
        /* Loading State */
        .loading {
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px;
            color: var(--gray-color);
        }
        
        .loading::after {
            content: '';
            width: 40px;
            height: 40px;
            border: 4px solid var(--light-color);
            border-top-color: var(--secondary-color);
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin-left: 15px;
        }
        
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <header>
        <div class="header-content">
            <h1>Freshers Recruitment Portal</h1>
            <p class="subtitle">Manage and review candidate profiles for recruitment</p>
        </div>
        <div style="display: flex; gap: 10px; align-items: center;">
            <a href="/students/new" class="btn-primary">
                Upload Student Records
            </a>
            <form action="/logout" method="POST" style="margin: 0;">
                <button type="submit" class="btn-primary" style="background-color: var(--accent-color);">
                    <i class="fa-solid fa-sign-out-alt"></i> Logout
                </button>
            </form>
        </div>
    </header>
    
    <!-- Search and Filter Section -->
    <div class="search-filter-container">
        <div class="search-section">
            <div class="search-input-group">
                <input 
                    type="text" 
                    class="search-input" 
                    id="searchInput" 
                    placeholder="Search by name, college, course, or skills..."
                >
                <span class="search-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
            </div>
            <button type="button" class="clear-search" id="clearSearch">
                Clear Search
            </button>
        </div>
        
        <div class="filter-section">
            <div class="filter-grid">
                <div class="filter-group">
                    <label class="filter-label">College</label>
                    <select class="filter-select" id="collegeFilter">
                        <option value="">All Colleges</option>
                        <% const colleges = [...new Set(students.map(s => s.college))]; %>
                        <% colleges.forEach(college => { %>
                            <option value="<%= college %>"><%= college %></option>
                        <% }); %>
                    </select>
                </div>
                
                <div class="filter-group">
                    <label class="filter-label">Course</label>
                    <select class="filter-select" id="courseFilter">
                        <option value="">All Courses</option>
                        <% const courses = [...new Set(students.map(s => s.course))]; %>
                        <% courses.forEach(course => { %>
                            <option value="<%= course %>"><%= course %></option>
                        <% }); %>
                    </select>
                </div>
                
                <div class="filter-group">
                    <label class="filter-label">CGPA Range</label>
                    <select class="filter-select" id="cgpaFilter">
                        <option value="">All CGPA</option>
                        <option value="9+">9.0+ (Excellent)</option>
                        <option value="8-9">8.0 - 8.9 (Very Good)</option>
                        <option value="7-8">7.0 - 7.9 (Good)</option>
                        <option value="6-7">6.0 - 6.9 (Average)</option>
                        <option value="<6">Below 6.0</option>
                    </select>
                </div>
                
                <div class="filter-group">
                    <label class="filter-label">Sort By</label>
                    <select class="filter-select" id="sortFilter">
                        <option value="name-asc">Name (A-Z)</option>
                        <option value="name-desc">Name (Z-A)</option>
                        <option value="cgpa-desc">CGPA (High to Low)</option>
                        <option value="cgpa-asc">CGPA (Low to High)</option>
                        <option value="college-asc">College (A-Z)</option>
                    </select>
                </div>
            </div>
            
            <div class="filter-actions">
                <div class="filter-results" id="filterResults">
                    Showing <strong><%= students.length %></strong> of <strong><%= students.length %></strong> students
                </div>
                <button type="button" class="clear-search" id="clearFilters">
                    Clear All Filters
                </button>
            </div>
            
            <div class="active-filters" id="activeFilters">
                <!-- Active filters will appear here -->
            </div>
        </div>
    </div>
    
    <!-- Stats Bar -->
    <div class="stats-bar">
        <div class="stat-item">
            <div class="stat-value" id="totalStudents"><%= students.length %></div>
            <div class="stat-label">Total Students</div>
        </div>
        <div class="stat-item">
            <div class="stat-value" id="filteredCount"><%= students.length %></div>
            <div class="stat-label">Currently Showing</div>
        </div>
        <div class="stat-item">
            <div class="stat-value" id="uniqueColleges"><%= new Set(students.map(s => s.college)).size %></div>
            <div class="stat-label">Unique Colleges</div>
        </div>
        <div class="stat-item">
            <div class="stat-value" id="uniqueCourses"><%= new Set(students.map(s => s.course)).size %></div>
            <div class="stat-label">Unique Courses</div>
        </div>
    </div>
    
    <!-- Empty State -->
    <div class="empty-state" id="emptyState" style="display: <%= students.length === 0 ? 'block' : 'none' %>;">
        <div>📁</div>
        <h3>No Student Records Found</h3>
        <p>Get started by uploading student records using the "Upload Student Records" button above.</p>
    </div>
    
    <!-- Loading State -->
    <div class="loading" id="loadingState" style="display: none;">
        Filtering students...
    </div>
    
    <!-- Student Cards -->
    <div class="card-container" id="studentCards">
    <% students.forEach(student => { %>
        <div class="card" 
        data-name="<%= (student.name || '').toLowerCase() %>" 
        data-college="<%= student.college || '' %>" 
        data-course="<%= student.course || '' %>"
        data-cgpa="<%= typeof student.cgpa !== 'undefined' && student.cgpa !== null ? student.cgpa : '' %>"
        data-skills="<%= (student.skills ? Object.values(student.skills).flat().join(',') : '').toLowerCase() %>">
            <div class="card-header">
                <h3><%= student.name || 'Unnamed' %></h3>
                <div class="card-id">ID: <%= (student.uuid || '').substring(0, 8) %></div>
            </div>
            
            <div class="card-details">
                <p>
                    <strong>College:</strong> 
                    <span><%= student.college || 'Not Provided' %></span>
                </p>
                <p>
                    <strong>Course:</strong> 
                    <span><%= student.course || 'Not Provided' %></span>
                </p>
                <p>
                    <strong>CGPA:</strong> 
                    <span class="cgpa-badge <%= (typeof student.cgpa === 'number') ? (student.cgpa >= 9 ? 'cgpa-high' : student.cgpa >= 8 ? 'cgpa-medium' : 'cgpa-low') : 'cgpa-low' %>">
                        <%= (typeof student.cgpa === 'number') ? student.cgpa : 'N/A' %>
                    </span>
                </p>
            </div>

            <div class="actions">
                <a href="/students/<%= student.uuid %>" class="btn btn-view">
                    👁 View Details
                </a>
            </div>
        </div>
    <% }); %>
    </div>
    
    <footer>
        <p>Freshers Recruitment Portal &copy; <%= new Date().getFullYear() %> | 
           <span id="footerCount"><%= students.length %></span> student records
        </p>
    </footer>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const studentCards = document.querySelectorAll('.card');
            const searchInput = document.getElementById('searchInput');
            const clearSearchBtn = document.getElementById('clearSearch');
            const clearFiltersBtn = document.getElementById('clearFilters');
            const collegeFilter = document.getElementById('collegeFilter');
            const courseFilter = document.getElementById('courseFilter');
            const cgpaFilter = document.getElementById('cgpaFilter');
            const sortFilter = document.getElementById('sortFilter');
            const filterResults = document.getElementById('filterResults');
            const activeFilters = document.getElementById('activeFilters');
            const emptyState = document.getElementById('emptyState');
            const loadingState = document.getElementById('loadingState');
            const totalStudents = document.getElementById('totalStudents');
            const filteredCount = document.getElementById('filteredCount');
            const footerCount = document.getElementById('footerCount');
            
            let currentFilters = {
                search: '',
                college: '',
                course: '',
                cgpa: '',
                sort: 'name-asc'
            };
            
            // Initialize with all students visible
            updateFilterResults(studentCards.length);
            
            // Search functionality
            searchInput.addEventListener('input', function() {
                currentFilters.search = this.value.toLowerCase().trim();
                applyFilters();
                updateActiveFilters();
            });
            
            // Filter functionality
            collegeFilter.addEventListener('change', function() {
                currentFilters.college = this.value;
                applyFilters();
                updateActiveFilters();
            });
            
            courseFilter.addEventListener('change', function() {
                currentFilters.course = this.value;
                applyFilters();
                updateActiveFilters();
            });
            
            cgpaFilter.addEventListener('change', function() {
                currentFilters.cgpa = this.value;
                applyFilters();
                updateActiveFilters();
            });
            
            sortFilter.addEventListener('change', function() {
                currentFilters.sort = this.value;
                applyFilters();
            });
            
            // Clear search
            clearSearchBtn.addEventListener('click', function() {
                searchInput.value = '';
                currentFilters.search = '';
                applyFilters();
                updateActiveFilters();
            });
            
            // Clear all filters
            clearFiltersBtn.addEventListener('click', function() {
                searchInput.value = '';
                collegeFilter.value = '';
                courseFilter.value = '';
                cgpaFilter.value = '';
                sortFilter.value = 'name-asc';
                
                currentFilters = {
                    search: '',
                    college: '',
                    course: '',
                    cgpa: '',
                    sort: 'name-asc'
                };
                
                applyFilters();
                updateActiveFilters();
            });
            
            // Apply all filters
            function applyFilters() {
                loadingState.style.display = 'block';
                
                setTimeout(() => {
                    let visibleCount = 0;
                    
                    studentCards.forEach(card => {
                        let isVisible = true;
                        const name = card.dataset.name;
                        const college = card.dataset.college;
                        const course = card.dataset.course;
                        const cgpa = parseFloat(card.dataset.cgpa);
                        const skills = card.dataset.skills;
                        
                        // Search filter
                        if (currentFilters.search) {
                            const searchTerm = currentFilters.search;
                            const searchInSkills = skills.includes(searchTerm);
                            const searchInName = name.includes(searchTerm);
                            const searchInCollege = college.toLowerCase().includes(searchTerm);
                            const searchInCourse = course.toLowerCase().includes(searchTerm);
                            
                            if (!(searchInName || searchInCollege || searchInCourse || searchInSkills)) {
                                isVisible = false;
                            }
                        }
                        
                        // College filter
                        if (currentFilters.college && college !== currentFilters.college) {
                            isVisible = false;
                        }
                        
                        // Course filter
                        if (currentFilters.course && course !== currentFilters.course) {
                            isVisible = false;
                        }
                        
                        // CGPA filter
                        if (currentFilters.cgpa) {
                            switch(currentFilters.cgpa) {
                                case '9+':
                                    if (cgpa < 9) isVisible = false;
                                    break;
                                case '8-9':
                                    if (cgpa < 8 || cgpa >= 9) isVisible = false;
                                    break;
                                case '7-8':
                                    if (cgpa < 7 || cgpa >= 8) isVisible = false;
                                    break;
                                case '6-7':
                                    if (cgpa < 6 || cgpa >= 7) isVisible = false;
                                    break;
                                case '<6':
                                    if (cgpa >= 6) isVisible = false;
                                    break;
                            }
                        }
                        
                        // Show/hide card
                        if (isVisible) {
                            card.style.display = 'block';
                            visibleCount++;
                            
                            // Add animation
                            card.style.opacity = '0';
                            card.style.transform = 'translateY(20px)';
                            setTimeout(() => {
                                card.style.transition = 'opacity 0.3s ease, transform 0.3s ease';
                                card.style.opacity = '1';
                                card.style.transform = 'translateY(0)';
                            }, 10);
                        } else {
                            card.style.display = 'none';
                        }
                    });
                    
                    // Sort cards
                    sortCards();
                    
                    // Update results
                    updateFilterResults(visibleCount);
                    
                    // Show/hide empty state
                    if (visibleCount === 0) {
                        emptyState.style.display = 'block';
                        emptyState.innerHTML = `
                            <div>🔍</div>
                            <h3>No Students Found</h3>
                            <p>No student records match your current search and filter criteria.</p>
                            <button class="clear-search" style="margin-top: 20px;" id="clearAllFromEmpty">
                                Clear All Filters
                            </button>
                        `;
                        
                        // Add event listener to clear button in empty state
                        document.getElementById('clearAllFromEmpty')?.addEventListener('click', function() {
                            clearFiltersBtn.click();
                        });
                    } else {
                        emptyState.style.display = 'none';
                    }
                    
                    loadingState.style.display = 'none';
                    
                }, 300); // Simulate loading delay
            }
            
            // Sort cards based on selected option
            function sortCards() {
                const container = document.getElementById('studentCards');
                const cardsArray = Array.from(studentCards).filter(card => card.style.display !== 'none');
                
                cardsArray.sort((a, b) => {
                    switch(currentFilters.sort) {
                        case 'name-asc':
                            return a.dataset.name.localeCompare(b.dataset.name);
                        case 'name-desc':
                            return b.dataset.name.localeCompare(a.dataset.name);
                        case 'cgpa-desc':
                            return parseFloat(b.dataset.cgpa) - parseFloat(a.dataset.cgpa);
                        case 'cgpa-asc':
                            return parseFloat(a.dataset.cgpa) - parseFloat(b.dataset.cgpa);
                        case 'college-asc':
                            return a.dataset.college.localeCompare(b.dataset.college);
                        default:
                            return 0;
                    }
                });
                
                // Reorder cards in DOM
                cardsArray.forEach(card => {
                    container.appendChild(card);
                });
            }
            
            // Update filter results display
            function updateFilterResults(count) {
                filteredCount.textContent = count;
                footerCount.textContent = count;
                
                const total = studentCards.length;
                filterResults.innerHTML = `
                    Showing <strong>${count}</strong> of <strong>${total}</strong> students
                    ${currentFilters.search || currentFilters.college || currentFilters.course || currentFilters.cgpa ? 
                    '<span style="color: var(--secondary-color); margin-left: 10px;">(Filtered)</span>' : ''}
                `;
            }
            
            // Update active filters display
            function updateActiveFilters() {
                activeFilters.innerHTML = '';
                
                if (currentFilters.search) {
                    addActiveFilter('search', `Search: "${currentFilters.search}"`);
                }
                
                if (currentFilters.college) {
                    addActiveFilter('college', `College: ${currentFilters.college}`);
                }
                
                if (currentFilters.course) {
                    addActiveFilter('course', `Course: ${currentFilters.course}`);
                }
                
                if (currentFilters.cgpa) {
                    let label = '';
                    switch(currentFilters.cgpa) {
                        case '9+': label = 'CGPA: 9.0+'; break;
                        case '8-9': label = 'CGPA: 8.0-8.9'; break;
                        case '7-8': label = 'CGPA: 7.0-7.9'; break;
                        case '6-7': label = 'CGPA: 6.0-6.9'; break;
                        case '<6': label = 'CGPA: Below 6.0'; break;
                    }
                    addActiveFilter('cgpa', label);
                }
            }
            
            function addActiveFilter(type, label) {
                const filterTag = document.createElement('div');
                filterTag.className = 'active-filter-tag';
                filterTag.innerHTML = `
                    ${label}
                    <button class="active-filter-remove" data-type="${type}">×</button>
                `;
                activeFilters.appendChild(filterTag);
                
                // Add remove functionality
                filterTag.querySelector('.active-filter-remove').addEventListener('click', function() {
                    const filterType = this.dataset.type;
                    
                    switch(filterType) {
                        case 'search':
                            searchInput.value = '';
                            currentFilters.search = '';
                            break;
                        case 'college':
                            collegeFilter.value = '';
                            currentFilters.college = '';
                            break;
                        case 'course':
                            courseFilter.value = '';
                            currentFilters.course = '';
                            break;
                        case 'cgpa':
                            cgpaFilter.value = '';
                            currentFilters.cgpa = '';
                            break;
                    }
                    
                    applyFilters();
                    updateActiveFilters();
                });
            }
            
            // Delete confirmation with student name
            const deleteForms = document.querySelectorAll('form[action*="/delete"]');
            
            deleteForms.forEach(form => {
                const deleteButton = form.querySelector('button[type="submit"]');
                
                deleteButton.addEventListener('click', function(e) {
                    const studentName = this.closest('.card').querySelector('h3').textContent;
                    const confirmed = confirm(`Are you sure you want to delete the record for "${studentName}"? This action cannot be undone.`);
                    
                    if (!confirmed) {
                        e.preventDefault();
                    }
                });
            });
            
            // Add subtle animation to cards on load
            studentCards.forEach((card, index) => {
                card.style.opacity = '0';
                card.style.transform = 'translateY(20px)';
                
                setTimeout(() => {
                    card.style.transition = 'opacity 0.5s ease, transform 0.5s ease';
                    card.style.opacity = '1';
                    card.style.transform = 'translateY(0)';
                }, index * 100);
            });
            
            // Add keyboard shortcut for search (Ctrl/Cmd + F)
            document.addEventListener('keydown', function(e) {
                if ((e.ctrlKey || e.metaKey) && e.key === 'f') {
                    e.preventDefault();
                    searchInput.focus();
                }
            });
        });
    </script>
</body>
</html>
